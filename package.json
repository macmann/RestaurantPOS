{
  "name": "restaurant-pos",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "typecheck": "npx tsc --noEmit",
    "build": "npx tsc -p tsconfig.json --outDir dist",
