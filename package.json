{
  "name": "restaurant-pos",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run build:api && npm run build:frontend",
    "test:e2e": "npm run build:api -- --noEmit false && node dist/tests/e2e-pos-flow.test.js",
    "dev:api": "tsx backend/server.ts",
    "start:api": "node dist/backend/server.js",
    "start": "npm run start:api",
    "dev:frontend": "npm run build:frontend && node scripts/preview-frontend.mjs",
    "build:frontend": "node scripts/build-frontend.mjs",
    "preview:frontend": "node scripts/preview-frontend.mjs",
    "start:frontend": "npm run preview:frontend",
    "build:api": "tsc -p tsconfig.json --outDir dist",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "test:integration": "npm run build:api -- --noEmit false && node dist/tests/sql-repositories.integration.test.js && node dist/tests/hardware-billing.integration.test.js",
    "test:unit": "npm run build:api -- --noEmit false && node dist/tests/order-authoritative-menu.unit.test.js"
  },
  "dependencies": {
    "express": "^4.18.3",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}
