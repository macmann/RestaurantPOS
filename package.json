    "start": "npm run start:api"
  },
  "dependencies": {
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  }
}
