# RestaurantPOS local network deployment template

# Environment
APP_ENV=development
APP_NAME=RestaurantPOS

# Branch/location reporting partition
POS_BRANCH_ID=main-floor
POS_BRANCH_NAME="Main Floor"
POS_LOCATION_LABEL="Main dining room"

# Network
HOST=0.0.0.0
PORT=8080
LAN_BASE_URL=http://192.168.1.100:8080

# Database
DB_CLIENT=postgres
DB_HOST=192.168.1.50
DB_PORT=5432
DB_NAME=restaurant_pos
DB_USER=pos_user
DB_PASSWORD=change_me
DB_SSL=false

# LAN reconnect/retry policy
POS_RECONNECT_INITIAL_DELAY_MS=500
POS_RECONNECT_MAX_DELAY_MS=10000
POS_RECONNECT_JITTER_MS=250
POS_RETRY_MAX_SAFE_ATTEMPTS=6
POS_RETRY_MAX_UNSAFE_ATTEMPTS=1
POS_HEALTH_CHECK_INTERVAL_MS=5000

# Locale and timezone
DEFAULT_LOCALE=en-US
DEFAULT_CURRENCY=USD
TIMEZONE=America/New_York

# Logging and auditing
LOG_LEVEL=info
AUDIT_RETENTION_DAYS=365
